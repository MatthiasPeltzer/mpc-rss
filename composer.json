{
  "name": "mpc/mpc-rss",
  "description": "TYPO3 extension to fetch and render RSS feeds grouped by category, date or author.",
  "homepage": "https://github.com/MatthiasPeltzer/mpc-rss",
  "authors": [
    {
      "name": "Matthias Peltzer",
      "email": "mail@mpeltzer.de",
      "homepage": "https://www.mpeltzer.de/",
      "role": "Developer"
    }
  ],
  "type": "typo3-cms-extension",
  "version": "1.2.2",
  "license": ["GPL-2.0-or-later"],
  "require": {
    "php": "^8.2",
    "typo3/cms-core": "^13.4 || ^14.3",
    "typo3/cms-fluid": "^13.4 || ^14.3",
    "typo3/cms-extbase": "^13.4 || ^14.3",
    "typo3/html-sanitizer": "^2.3"
  },
  "autoload": {
    "psr-4": {
      "Mpc\\MpcRss\\": "Classes/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Mpc\\MpcRss\\Tests\\": "Tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5",
    "typo3/testing-framework": "^9.5"
  },
  "config": {
    "allow-plugins": {
      "typo3/class-alias-loader": true,
      "typo3/cms-composer-installers": true
    }
  },
  "scripts": {
    "test:unit": "phpunit -c phpunit.xml.dist",
    "test:functional": "phpunit -c phpunit.functional.xml.dist"
  },
  "extra": {
    "typo3/cms": {
      "extension-key": "mpc_rss"
    }
  }
}

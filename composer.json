{
  "name": "mpc/mpc-rss",
  "description": "TYPO3 extension to fetch and render RSS feeds grouped by category, date or author.",
  "homepage": "https://github.com/MatthiasPeltzer/mpc-rss",
  "authors": [
    {
      "name": "Matthias Peltzer",
      "email": "mail@mpeltzer.de",
      "homepage": "https://www.mpeltzer.de/",
      "role": "Developer"
    }
  ],
  "type": "typo3-cms-extension",
  "version": "1.0.7",
  "license": ["GPL-2.0-or-later"],
  "require": {
    "php": "^8.2",
    "typo3/cms-core": "^13.0 || ^14.0",
    "typo3/cms-fluid": "^13.0 || ^14.0",
    "typo3/cms-extbase": "^13.0 || ^14.0",
    "typo3/cms-fluid-styled-content": "^13.0 || ^14.0"
  },
  "autoload": {
    "psr-4": {
      "Mpc\\MpcRss\\": "Classes/"
    }
  },
  "extra": {
    "typo3/cms": {
      "extension-key": "mpc_rss"
    }
  }
}
